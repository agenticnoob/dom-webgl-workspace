{
  "name": "@viselora/scroll-adapters",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup src/index.ts src/react.ts --format esm --dts --sourcemap --clean --splitting false --out-dir dist",
    "postbuild": "node ../../scripts/finalize-package-dts.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agenticnoob/dom-webgl-workspace.git",
    "directory": "packages/dom-webgl-scroll-adapters"
  },
  "bugs": {
    "url": "https://github.com/agenticnoob/dom-webgl-workspace/issues"
  },
  "homepage": "https://github.com/agenticnoob/dom-webgl-workspace#readme",
  "keywords": [
    "viselora",
    "webgl",
    "scroll",
    "lenis",
    "gsap"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "gsap": ">=3.12.0",
    "lenis": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "gsap": {
      "optional": true
    },
    "lenis": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@viselora/dom-webgl": "0.1.0-alpha.1"
  }
}
